{
  "name": "wse2-launcher",
  "version": "1.0.9",
  "description": "Warband Script Enhancer 2 Launcher By Azremen",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azremen/wse2-custom-launcher.git"
  },
  "main": "main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Azremen <timurid76@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run dist:all",
    "dist:all": "electron-builder --linux --win",
    "release": "electron-builder --linux --win -p always",
    "release:local": "dotenv -e .env -- electron-builder --linux --win -p always",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.azremen.wse2-launcher",
    "productName": "wse2-launcher",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp}",
      "!.vscode/",
      "!**/*.{ts,tsx,map}",
      "!Modules/",
      "!scripts/",
      "!*.log",
      "!.git/"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Windows-Portable.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-Linux.${ext}",
      "category": "Game",
      "icon": "icons/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Azremen",
        "repo": "wse2-custom-launcher",
        "releaseType": "release"
      },
      {
        "provider": "github",
        "owner": "Azremen",
        "repo": "WSE2-Launcher",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-Mac.${ext}",
      "icon": "icons/icon.icns"
    }
  },
  "keywords": [
    "Mount & Blade",
    "Warband",
    "Warband Script Enhancer 2",
    "Launcher"
  ],
  "devDependencies": {
    "@electron/asar": "^4.0.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "bootstrap": "^5.3.8",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7",
    "ini": "^4.1.1",
    "jquery": "^4.0.0"
  }
}
