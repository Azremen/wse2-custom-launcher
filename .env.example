# Path to your code signing certificate (PFX file)
CSC_LINK=./wse2-cert.pfx

# Password for the certificate
CSC_KEY_PASSWORD=your_password_here

# GitHub Token (for manual local development/build)
# Only needed if you run 'npm run release' from your local PC.
# Not needed for GitHub Actions.
GH_TOKEN=ghp_your_github_token_here
